{
  "expo": {
    "name": "AtoZ",
    "slug": "AtoZ",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/new_app_logo.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/atoz-splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#034ea1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "entitlements": {
        "com.apple.developer.networking.wifi-info": true
      },
      "splash": {
        "image": "./assets/atoz-splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#034ea1"
      },
      "bundleIdentifier": "com.atoz.client",
      "buildNumber": "15",
      "supportsTablet": false,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "NSLocationWhenInUseUsageDescription": "Allow a-to-z client app to use your location for better job assignment",
        "NSLocationUsageDescription": "Allow a-to-z client app to use your location for better job assignment",
        "NSLocationAlwaysUsageDescription": "Allow a-to-z client app to use your location for better job assignment",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow a-to-z client app to use your location for better job assignment"
      }
    },
    "android": {
      "splash": {
        "image": "./assets/atoz-splash.png",
        "resizeMode": "contain",
        "backgroundColor": "#034ea1"
      },
      "package": "com.atoz.client",
      "googleServicesFile": "./google-services.json",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/new_app_logo.png",
        
        "backgroundColor": "#fff"
      },
      "useNextNotificationsApi": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8e79206b-a207-4d76-93ac-7bfd41d2fbaf"
      }
    }
  }
}
